{
  "name": "crown-island",
  "version": "0.1.0",
  "private": true,
  "description": "Crown Island - El Montazah premium booking PWA",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "dev:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev",
    "build": "next build",
    "deploy:db": "prisma migrate deploy",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit",
    "test:unit": "node scripts/run-tests.mjs unit",
    "test:integration": "node scripts/run-tests.mjs integration",
    "format": "prettier --write .",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up",
    "docker:up:detached": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:down:volumes": "docker compose down -v",
    "docker:logs": "docker compose logs -f app",
    "db:seed": "tsx prisma/seed.ts",
    "admin:promote": "tsx scripts/promote-admin.ts",
    "admin:create": "tsx scripts/create-admin.ts",
    "postinstall": "prisma generate"
  },
  "overrides": {
    "dompurify": "^3.4.11",
    "exceljs": {
      "uuid": "^11.1.1"
    },
    "postcss": "$postcss"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^6.19.3",
    "@reduxjs/toolkit": "^2.5.0",
    "@zxing/library": "^0.21.3",
    "bcryptjs": "^2.4.3",
    "browser-image-compression": "^2.0.2",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "framer-motion": "^11.15.0",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "jsqr": "^1.4.0",
    "leaflet": "^1.9.4",
    "libphonenumber-js": "^1.13.5",
    "lucide-react": "^0.469.0",
    "next": "^16.2.6",
    "next-auth": "5.0.0-beta.31",
    "next-intl": "^4.12.0",
    "prisma": "^6.19.3",
    "qrcode": "^1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-leaflet": "^5.0.0",
    "react-redux": "^9.2.0",
    "recharts": "^3.8.1",
    "resend": "^6.12.3",
    "tailwind-merge": "^2.6.0",
    "web-push": "^3.6.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/leaflet": "^1.9.15",
    "@types/node": "^22.10.5",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5.10",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
