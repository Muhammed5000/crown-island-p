# dependencies
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# testing
coverage/
docs/

# next.js
.next/
out/

# production
build/
dist/

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
# stray dev/build logs (dev_output.log, dev_error.log, .next-prod-start.log, …)
*.log

# local env files — NEVER commit real secrets. Commit .env.example only.
.env
.env.docker
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
.env.*

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma — local SQLite dev database is a build artifact, never version it
prisma/dev.db
prisma/dev.db-journal
prisma/*.db
prisma/*.db-journal

# editors
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# pwa
# public/sw.js
# public/workbox-*.js
# public/sw.js.map
# public/workbox-*.js.map

# admin uploads — keep the folder, ignore everything in it
public/uploads/*
!public/uploads/.gitkeep

# private uploads — SENSITIVE (guest IDs, payment/ops proofs), never committed,
# served only via the auth-gated /api/secure-media route.
private-uploads/

# Code-graph tool output (never commit)
graphify-out/

# Security audit deliverables — SENSITIVE (document live weaknesses / takeover
# primitives). Keep on the ops box, never commit to a public remote.
REVIEW_FULL_PROJECT.md
/REVIEW_*.md
